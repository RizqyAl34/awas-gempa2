<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F6">

    <!-- ===================================================
         HEADER
         =================================================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="24dp"
        android:background="#FFF8F6"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_bot_avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/robot"
            android:padding="4dp"
            android:background="@drawable/bg_severity_high"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/iv_bot_avatar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AWAS GEMPA Bot"
                android:fontFamily="@font/manrope_bold"
                android:textSize="16sp"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Online · Data BMKG Real-time"
                android:textSize="11sp"
                android:textColor="#2E7D32" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divider -->
    <View
        android:id="@+id/divider_header"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0EEEC"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- ===================================================
         RECYCLERVIEW CHAT
         =================================================== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/divider_header"
        app:layout_constraintBottom_toTopOf="@id/quick_reply_scroll" />

    <!-- ===================================================
         QUICK REPLY CHIPS (scrollable horizontal)
         =================================================== -->
    <HorizontalScrollView
        android:id="@+id/quick_reply_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@id/input_container">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_1"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_chip"
                android:textSize="12sp"
                android:textColor="#AF101A"
                android:text="Gempa terbaru apa?" />

            <TextView
                android:id="@+id/chip_2"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_chip"
                android:textSize="12sp"
                android:textColor="#AF101A"
                android:text="Apakah aman di lokasi saya?" />

            <TextView
                android:id="@+id/chip_3"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_chip"
                android:textSize="12sp"
                android:textColor="#AF101A"
                android:text="Cara evakuasi?" />

            <TextView
                android:id="@+id/chip_4"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_chip"
                android:textSize="12sp"
                android:textColor="#AF101A"
                android:text="Apa itu skala richter?" />

            <TextView
                android:id="@+id/chip_5"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_chip"
                android:textSize="12sp"
                android:textColor="#AF101A"
                android:text="Tips tas darurat" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ===================================================
         INPUT BAR
         =================================================== -->
    <LinearLayout
        android:id="@+id/input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="#FFF8F6"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <EditText
            android:id="@+id/et_chat_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:hint="Tanya tentang gempa..."
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3" />

        <ImageView
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:padding="12dp"
            android:src="@drawable/notifications"
            android:background="@drawable/bg_severity_high"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- ===================================================
         BOTTOM NAV
         =================================================== -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="12dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/nav_chatbot"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_nav_active"
            android:padding="12dp"
            android:src="@drawable/robot"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/nav_home"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            android:padding="12dp"
            android:src="@drawable/grid" />

        <ImageView
            android:id="@+id/nav_maps"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/explore" />

        <ImageView
            android:id="@+id/nav_alerts"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="20dp"
            android:padding="12dp"
            android:src="@drawable/notifications" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>