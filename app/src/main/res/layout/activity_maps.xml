<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F6">

    <!-- =====================================================
         1. PETA OSM (FULL SCREEN, DI BELAKANG SEMUA)
         ===================================================== -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay gradient tipis agar konten di atas lebih terbaca -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/map_overlay_gradient" />

    <!-- =====================================================
         2. HEADER
         ===================================================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AWAS GEMPA"
            android:textColor="#AF101A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- =====================================================
         3. SEARCH BAR
         ===================================================== -->
    <LinearLayout
        android:id="@+id/floating_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_search_blur"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/search"
                app:tint="#5B403D" />

            <EditText
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Cari wilayah..."
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- =====================================================
         4. DETAIL CARD — DIISI OTOMATIS DARI BMKG
         Semua TextView punya ID agar bisa diupdate dari Java
         ===================================================== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/detail_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="116dp"
        app:cardBackgroundColor="#F5FFF8F6"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Label: "⚠ CRITICAL ALERT" / "● ACTIVE ALERT" / "● INFO" -->
            <!-- ID: alert_label → diupdate dari Java -->
            <TextView
                android:id="@+id/alert_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memuat data..."
                android:textColor="#AF101A"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Magnitudo besar di kanan atas -->
            <!-- ID: magnitude_text → diupdate dari Java -->
            <TextView
                android:id="@+id/magnitude_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:text="—"
                android:textColor="#AF101A"
                android:textSize="48sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Nama lokasi / wilayah gempa -->
            <!-- ID: location_name → diupdate dari Java -->
            <TextView
                android:id="@+id/location_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Memuat lokasi..."
                android:textSize="18sp"
                android:textColor="#1A1A1A"
                app:layout_constraintEnd_toStartOf="@id/magnitude_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/alert_label" />

            <!-- Kedalaman gempa -->
            <!-- ID: tv_quake_depth → diupdate dari Java -->
            <TextView
                android:id="@+id/tv_quake_depth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.6"
                android:text="Kedalaman: —"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/location_name" />

            <!-- Waktu gempa -->
            <!-- ID: tv_quake_time → diupdate dari Java -->
            <TextView
                android:id="@+id/tv_quake_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:alpha="0.6"
                android:text="— · —"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_quake_depth" />

            <!-- Tombol lihat rute evakuasi -->
            <Button
                android:id="@+id/btn_evacuation"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#AF101A"
                android:text="LIHAT RUTE EVAKUASI"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:cornerRadius="100dp"
                app:layout_constraintTop_toBottomOf="@id/tv_quake_time" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- =====================================================
         5. BOTTOM NAV
         ===================================================== -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="12dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/nav_chatbot"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/robot" />

        <ImageView
            android:id="@+id/nav_home"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            android:padding="12dp"
            android:src="@drawable/grid" />

        <ImageView
            android:id="@+id/nav_maps"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_nav_active"
            android:padding="12dp"
            android:src="@drawable/explore"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/nav_alerts"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="20dp"
            android:padding="12dp"
            android:src="@drawable/notifications" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>